# MongoDB Atlas M0 — free forever (512MB)
# Get from: cloud.mongodb.com → Connect → Drivers → copy connection string
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/movie-recs

# Google Gemini Flash — free tier (1500 req/day, 1M tokens/day)
# Get from: aistudio.google.com → Get API Key
GEMINI_API_KEY=your_google_ai_studio_key_here

# TMDB API — free, unlimited requests
# Get from: themoviedb.org → Settings → API → Developer
TMDB_API_KEY=your_tmdb_api_key_here

# Your frontend URL (for CORS)
# Local dev: http://localhost:5173
# Production: https://your-app.vercel.app (set after first deploy)
FRONTEND_URL=http://localhost:5173
